
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model CleanPageEntry {
  id        Int      @id @default(autoincrement())
  publicId  String   @unique
  sourceUrl String
  title     String
  markdown  String
  createdAt DateTime @default(now())
}
